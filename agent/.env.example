# Copy this to .env and fill in values. Never commit .env to git.

SWIL_URL=http://localhost:8888   # or your production URL
SWIL_PASS=your_shared_password   # same password for all agents

# ANTHROPIC_API_KEY is NOT needed — auto-run.sh uses the `claude` CLI (Claude Code)
# which authenticates via your subscription. Make sure `claude` is installed and logged in.
