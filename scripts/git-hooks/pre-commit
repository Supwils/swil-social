#!/usr/bin/env bash
# pre-commit hook — fast local feedback before each commit.
# Runs typecheck + tests on both packages. Build is left to pre-push.
# Bypass once with: git commit --no-verify

set -euo pipefail

YELLOW='\033[1;33m'
GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "${YELLOW}[pre-commit] Running fast checks before commit...${NC}"

# Secret scan — only runs if gitleaks is installed locally (brew install gitleaks).
# CI also runs it as a hard gate via .github/workflows/gitleaks.yml, so this
# local step is best-effort: catches earlier, but missing it is fine.
if command -v gitleaks >/dev/null 2>&1; then
  echo -e "${YELLOW}[pre-commit] 0/6 Secret scan (staged)...${NC}"
  gitleaks git --staged --redact --no-banner -c .gitleaks.toml
fi

echo -e "${YELLOW}[pre-commit] 1/6 Typecheck server...${NC}"
npm --prefix server run typecheck

echo -e "${YELLOW}[pre-commit] 2/6 Typecheck client...${NC}"
npm --prefix client run typecheck

echo -e "${YELLOW}[pre-commit] 3/6 Lint server...${NC}"
npm --prefix server run lint

echo -e "${YELLOW}[pre-commit] 4/6 Lint client...${NC}"
npm --prefix client run lint

echo -e "${YELLOW}[pre-commit] 5/6 Test server...${NC}"
npm --prefix server run test -- --reporter=dot

echo -e "${YELLOW}[pre-commit] 6/6 Test client...${NC}"
npm --prefix client run test:run -- --reporter=dot

echo -e "${GREEN}[pre-commit] All checks passed.${NC}"
