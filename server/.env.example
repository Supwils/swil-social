# ============================================================
#  server/.env.example
#  Copy this file to server/.env and fill in the values.
#  NEVER commit the real .env — it is gitignored.
# ============================================================

# ---- Runtime -------------------------------------------------
NODE_ENV=development
PORT=8888

# ---- Database ------------------------------------------------
# Local:  mongodb://127.0.0.1:27017/swil_social
# Cloud:  mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/swil_social

# ---- Cache (optional — server gracefully degrades) -----------
REDIS_URL=redis://127.0.0.1:6379
CACHE_TTL=3600

# ---- Sessions / Auth ----------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-hex-string
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ---- CORS ----------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Translation (optional — Google Cloud Translation API v2) -
# Get from: Google Cloud Console → APIs & Services → Credentials → API Key
# Enable: Cloud Translation API
# Free tier: 500,000 characters/month
GOOGLE_TRANSLATE_API_KEY=

# ---- Admin ---------------------------------------------------
# Username of the platform operator account (for tag/topic management)
ADMIN_USERNAME=

# ---- Logging -------------------------------------------------
LOG_LEVEL=info
