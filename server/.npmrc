# Use legacy peer-dependency resolution.
#
# Why: eslint-plugin-react@7.37.x declares a peer of `eslint <= 9.x`, but we
# install eslint@10. The plugin works correctly with eslint 10 in practice
# (verified via `npm run lint` passing across the codebase), but `npm ci`
# rejects the install without this flag.
#
# Same situation for a few other dev deps that pin `react@^17 || ^18` while
# we're on react 18 — npm 7+ enforces peers strictly by default.
#
# Re-evaluate when eslint-plugin-react@8 ships with eslint 10 in its peer
# range — at that point we can drop this file.
legacy-peer-deps=true
